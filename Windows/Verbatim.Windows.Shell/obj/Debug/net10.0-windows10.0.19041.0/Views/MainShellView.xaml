<?xml version="1.0" encoding="utf-8"?>
<UserControl x:ConnectionId='1'
    x:Class="Verbatim.Windows.Shell.Views.MainShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:contracts="using:Verbatim.Contracts"
    xmlns:viewModels="using:Verbatim.Windows.Shell.ViewModels">
    <UserControl.Resources>
        <SolidColorBrush x:Key="VerbatimAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="VerbatimMutedBrush" Color="#475569" />
        <Style x:Key="ProminentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource VerbatimAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:ConnectionId='2'
            Margin="16,16,16,0"
            IsClosable="False"
                                                                     
                                                                    />

        <NavigationView x:ConnectionId='3'
            Grid.Row="1"
            x:Name="ShellNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
                                           
                                                              >
            <NavigationView.PaneHeader>
                <StackPanel Margin="8,20,8,12" Spacing="4">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Verbatim" />
                    <TextBlock Foreground="{StaticResource VerbatimMutedBrush}" Text="Cross-platform local shell" />
                </StackPanel>
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="home" />
                <NavigationViewItem Content="Dictionary" Icon="Library" Tag="dictionary" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
                <NavigationViewItem Content="Support" Icon="Help" Tag="support" />
            </NavigationView.MenuItems>

            <Grid Padding="20">
                <ScrollViewer x:ConnectionId='8'                                                            >
                    <StackPanel Spacing="18">
                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="Home" />
                                    <TextBlock Foreground="{StaticResource VerbatimMutedBrush}" Text="The Windows shell is using the shared loopback JSON contract." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button x:ConnectionId='81'                                    Content="Start / Stop Dictation" Style="{StaticResource ProminentButtonStyle}" />
                                    <Button x:ConnectionId='82'                             Content="Refresh" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="20">
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Provider catalog" />
                                <ItemsControl x:ConnectionId='74'                                                        >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                             >
                                            <Border x:ConnectionId='76' Margin="0,0,0,10" Padding="14" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="16">
                                                <StackPanel Spacing="6">
                                                    <TextBlock x:ConnectionId='77' FontSize="16" FontWeight="SemiBold"                             />
                                                    <TextBlock x:ConnectionId='78' Foreground="{StaticResource VerbatimMutedBrush}"                                     />
                                                    <TextBlock x:ConnectionId='79' Foreground="{StaticResource VerbatimMutedBrush}"                                   TextWrapping="WrapWholeWords" />
                                                    <TextBlock x:ConnectionId='80' Foreground="{StaticResource VerbatimMutedBrush}"                                      TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="20">
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="History" />
                                <TextBox x:ConnectionId='61' PlaceholderText="Search history"                                                                                        />
                                <Button x:ConnectionId='62'                                  HorizontalAlignment="Left" Content="Clear history" />
                                <ItemsControl x:ConnectionId='63'                                                              >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                       >
                                            <StackPanel x:ConnectionId='65' Margin="0,0,0,14" Spacing="8">
                                                <TextBlock x:ConnectionId='66' FontWeight="SemiBold"                       />
                                                <ItemsControl x:ConnectionId='67'                             >
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate                                      >
                                                            <Border x:ConnectionId='69' Margin="0,0,0,8" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="14">
                                                                <Grid ColumnSpacing="12">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock x:ConnectionId='71' FontWeight="SemiBold"                            />
                                                                        <TextBlock x:ConnectionId='72'                           TextWrapping="WrapWholeWords" />
                                                                        <TextBlock x:ConnectionId='73' Foreground="{StaticResource VerbatimMutedBrush}"                       TextWrapping="WrapWholeWords" />
                                                                    </StackPanel>
                                                                    <Button x:ConnectionId='70' Grid.Column="1"                                                     Content="Delete" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:ConnectionId='9'                                                                  >
                    <StackPanel Spacing="18">
                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Dictionary" />
                                <TextBlock Foreground="{StaticResource VerbatimMutedBrush}" Text="Manage vocabulary hints through the shared service." TextWrapping="WrapWholeWords" />
                                <TextBox x:ConnectionId='58' Header="Phrase"                                                         />
                                <TextBox x:ConnectionId='59' Header="Hint"                                                       />
                                <Button x:ConnectionId='60'                                    HorizontalAlignment="Left" Content="Add entry" Style="{StaticResource ProminentButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:ConnectionId='52'                                                                >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate                                          >
                                    <Border x:ConnectionId='54' Margin="0,0,0,10" Padding="14" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="16">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock x:ConnectionId='56' FontWeight="SemiBold"                        />
                                                <TextBlock x:ConnectionId='57' Foreground="{StaticResource VerbatimMutedBrush}"                      TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                            <Button x:ConnectionId='55' Grid.Column="1"                                                        Content="Delete" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:ConnectionId='10'                                                                >
                    <StackPanel Spacing="18">
                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />
                                <TextBlock Foreground="{StaticResource VerbatimMutedBrush}" Text="Choose providers, models, language, overlay, and hotkey capture from the Windows shell." TextWrapping="WrapWholeWords" />
                                <TextBlock FontWeight="SemiBold" Text="Current provider" />
                                <TextBlock x:ConnectionId='42'                                                          />
                                <ItemsControl x:ConnectionId='43'                                                              >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                       >
                                            <Border x:ConnectionId='48' Margin="0,0,0,10" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock x:ConnectionId='50' FontWeight="SemiBold"                       />
                                                        <TextBlock x:ConnectionId='51' Foreground="{StaticResource VerbatimMutedBrush}"                      TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                    <Button x:ConnectionId='49' Grid.Column="1"                                                      Content="Select"                              />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ComboBox x:ConnectionId='44'
                                    x:Name="LanguageComboBox"
                                    Header="Preferred language"
                                    DisplayMemberPath="Label"
                                                                                                 
                                                                                                     
                                    SelectedValuePath="Id"
                                                                                         />

                                <ToggleSwitch x:ConnectionId='45'
                                    x:Name="OverlayToggle"
                                    Header="Overlay enabled"
                                                                                         
                                                                    />

                                <TextBox x:ConnectionId='46'
                                    x:Name="HotkeyCaptureBox"
                                    Header="Hotkey capture"
                                    PlaceholderText="Focus here and press a key combination"
                                                                                        
                                                                       />
                            </StackPanel>
                        </Border>

                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Whisper models" />
                                <ItemsControl x:ConnectionId='33'                                                            >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                      >
                                            <Border x:ConnectionId='35' Margin="0,0,0,10" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:ConnectionId='39' FontWeight="SemiBold"                                 />
                                                        <TextBlock x:ConnectionId='40' Foreground="{StaticResource VerbatimMutedBrush}"                                   />
                                                        <TextBlock x:ConnectionId='41' Foreground="{StaticResource VerbatimMutedBrush}"                       />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                        <Button x:ConnectionId='36'                                                                     Content="Select" />
                                                        <Button x:ConnectionId='37'                                                                       Content="Download" />
                                                        <Button x:ConnectionId='38'                                                                     Content="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Parakeet models" />
                                <ItemsControl x:ConnectionId='24'                                                             >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                      >
                                            <Border x:ConnectionId='26' Margin="0,0,0,10" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:ConnectionId='30' FontWeight="SemiBold"                                 />
                                                        <TextBlock x:ConnectionId='31' Foreground="{StaticResource VerbatimMutedBrush}"                                   />
                                                        <TextBlock x:ConnectionId='32' Foreground="{StaticResource VerbatimMutedBrush}"                       />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                        <Button x:ConnectionId='27'                                                                      Content="Select" />
                                                        <Button x:ConnectionId='28'                                                                        Content="Download" />
                                                        <Button x:ConnectionId='29'                                                                      Content="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:ConnectionId='11'                                                               >
                    <StackPanel Spacing="18">
                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Support" />
                                <TextBlock x:ConnectionId='19'                                                           />
                                <TextBlock x:ConnectionId='20'                                                           />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:ConnectionId='21'                                            Content="Microphone settings" />
                                    <Button x:ConnectionId='22'                                               Content="Accessibility settings" />
                                    <Button x:ConnectionId='23'                                     Content="Reset onboarding" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="20">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Diagnostics" />
                                <ItemsControl x:ConnectionId='12'                                                          >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                                             >
                                            <Border x:ConnectionId='14' Margin="0,0,0,10" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock x:ConnectionId='16' FontWeight="SemiBold"                             />
                                                        <TextBlock x:ConnectionId='17' Foreground="{StaticResource VerbatimMutedBrush}"                                   TextWrapping="WrapWholeWords" />
                                                        <TextBlock x:ConnectionId='18' Foreground="{StaticResource VerbatimMutedBrush}"                                              TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                    <Button x:ConnectionId='15' Grid.Column="1"                                                              Content="Restart runtime" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>

        <Grid x:ConnectionId='4' Background="#AA0F172A"                                                                  >
            <Border
                Width="760"
                Padding="28"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock FontSize="32" FontWeight="SemiBold" Text="Welcome to Verbatim for Windows" />
                    <TextBlock Foreground="{StaticResource VerbatimMutedBrush}" Text="The provider catalog, history store, dictionary, diagnostics, model management, and loopback service are now available from the Windows shell." TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:ConnectionId='6'                                            Content="Open microphone settings" />
                        <Button x:ConnectionId='7'                                        Content="Continue" Style="{StaticResource ProminentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <ProgressRing x:ConnectionId='5'
                                                             
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,24" />
    </Grid>
</UserControl>

