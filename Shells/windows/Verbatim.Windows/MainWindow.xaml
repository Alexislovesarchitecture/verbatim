<Window
    x:Class="Verbatim.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verbatim"
    Width="1320"
    Height="920">
    <ScrollViewer>
        <Grid Padding="24" ColumnSpacing="18" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.ColumnSpan="3" Spacing="4">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="Verbatim" />
                <TextBlock x:Name="StatusTextBlock" Opacity="0.78" Text="Loading Windows shell state..." TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="1" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Provider and Language" />
                    <TextBlock x:Name="ProviderDetailTextBlock" TextWrapping="Wrap" />
                    <ComboBox x:Name="ProviderComboBox" Header="Preferred provider" SelectionChanged="ProviderComboBox_SelectionChanged" />
                    <ComboBox x:Name="LanguageComboBox" Header="Language" SelectionChanged="LanguageComboBox_SelectionChanged" />
                    <TextBlock x:Name="SelectedProviderMessageTextBlock" TextWrapping="Wrap" />
                    <TextBlock x:Name="PermissionTextBlock" TextWrapping="Wrap" />
                    <Button Content="Open Microphone Settings" Click="OpenPermissionSettingsButton_Click" />
                    <Button Content="Refresh Status" Click="RefreshButton_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Models and Runtime" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="WhisperModelComboBox" Header="Whisper model" SelectionChanged="WhisperModelComboBox_SelectionChanged" />
                        <ComboBox x:Name="ParakeetModelComboBox" Grid.Column="1" Header="Parakeet model" SelectionChanged="ParakeetModelComboBox_SelectionChanged" />
                    </Grid>
                    <ProgressBar x:Name="ModelProgressBar" Minimum="0" Maximum="1" Height="10" Visibility="Collapsed" />
                    <TextBlock x:Name="ModelProgressTextBlock" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="InstallModelButton" Content="Install Selected Model" Click="InstallModelButton_Click" />
                        <Button Content="Copy Latest Transcript" Click="CopyLatestButton_Click" />
                        <Button x:Name="RecordButton" Content="Start Recording" Click="RecordButton_Click" />
                    </StackPanel>
                    <ListView x:Name="ProviderSummaryListView" Height="220" />
                    <ListView x:Name="RuntimeListView" Height="140" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Diagnostics and Tips" />
                    <ListView x:Name="DiagnosticsListView" Height="210" />
                    <ListView x:Name="TipsListView" Height="170" />
                    <TextBlock FontWeight="SemiBold" Text="Focused Context" />
                    <TextBlock x:Name="FocusTextBlock" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="History" />
                    <TextBlock x:Name="PathsTextBlock" TextWrapping="Wrap" />
                    <ListView x:Name="HistoryListView" Height="430" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="1" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Dictionary" />
                    <ListView x:Name="DictionaryListView" Height="430" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Padding="18" CornerRadius="16" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Product Notes" />
                    <TextBlock TextWrapping="Wrap" Text="Windows is a first-class Verbatim shell. Apple Speech remains selectable but unsupported here, Whisper is cross-platform, and Parakeet activates only when Windows and NVIDIA CUDA capability checks pass." />
                    <TextBlock TextWrapping="Wrap" Text="The shell keeps provider-specific languages persistent, exposes install progress and runtime readiness, and relies on the shared Rust core for capability reduction, selection resolution, and deterministic transcript cleanup." />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
